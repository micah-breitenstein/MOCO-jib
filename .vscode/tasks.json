{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Arduino CLI: Build Mega master",
			"type": "shell",
			"command": "arduino-cli",
			"args": [
				"compile",
				"--fqbn",
				"arduino:avr:mega",
				"${workspaceFolder}/MEGA__master"
			],
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"problemMatcher": []
		},
		{
			"label": "Arduino CLI: Upload Mega master",
			"type": "shell",
			"command": "arduino-cli",
			"args": [
				"upload",
				"-v",
				"-p",
				"/dev/cu.usbmodem1301",
				"--fqbn",
				"arduino:avr:mega",
				"${workspaceFolder}/MEGA__master"
			],
			"group": "build"
		}
	]
}